/target
.DS_Store
# Screenshots (P) and clips (R) land here; never commit captures.
/images/
/clips/
*.gb
*.gbc
*.sav
*.sav.tmp
# Save states (digit keys) and their thumbnail sidecars land next to the ROM.
*.ss[0-9]
*.thumb
!crates/termboy-gb/tests/roms/**/*.gb
docs/superpowers/
# Track the roms/ folder (placeholder README) but never the ROMs/saves in it.
/roms/*
!/roms/README.md
!crates/termboy-gb/tests/roms/**/*.gbc
*.gba
!crates/termboy-gba/tests/roms/*.gba
# mGBA suite is a local-only diagnostic (scripts/fetch-mgba-suite.sh), never committed.
crates/termboy-gba/tests/roms-local/
